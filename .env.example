# PolyBit configuration. Copy to `.env` and fill in your own values.
#
# DO NOT commit your real .env to git. The .gitignore already excludes it.

# Bitquery OAuth / API token from https://account.bitquery.io/user/api_v2/access_tokens
BITQUERY_TOKEN=

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Optional: log level (DEBUG, INFO, WARNING, ERROR). Default INFO.
POLYBIT_LOG_LEVEL=INFO

# Optional: where to store users.json + alerts.json. Defaults to <repo>/data
# for local dev. In production (Render, Hetzner, etc.) point this at a
# persistent disk mount (e.g. /var/data on Render) so user data survives
# redeploys and restarts.
# POLYBIT_DATA_DIR=/var/data
